    <!-- SERVLET MAPPING -->
    <servlet-mapping>
        <servlet-name>Faces Servlet</servlet-name>
        <url-pattern>/faces/*</url-pattern>
    </servlet-mapping>

    <!-- WELCOME FILES (Arquivo padrão ao acessar a aplicação) -->
    <welcome-file-list>
        <welcome-file>faces/login.xhtml</welcome-file>
    </welcome-file-list>

    <!-- MIME MAPPINGS PARA O TEMPLATE MANHATTAN -->
    <!-- Fontes WOFF2 -->
    <mime-mapping>
        <extension>woff2</extension>
        <mime-type>application/x-font-woff2</mime-type>
    </mime-mapping>

    <!-- Fontes EOT -->
    <mime-mapping>
        <extension>eot</extension>
        <mime-type>application/vnd.ms-fontobject</mime-type>
    </mime-mapping>

    <!-- Fontes WOFF -->
    <mime-mapping>
        <extension>woff</extension>
        <mime-type>application/x-font-woff</mime-type>
    </mime-mapping>

    <!-- Fontes TTF -->
    <mime-mapping>
        <extension>ttf</extension>
        <mime-type>application/x-font-ttf</mime-type>
    </mime-mapping>

    <!-- PARÂMETROS DE CONTEXTO PARA PRIMEFACES -->
    
    <!-- Desabilitar Font Awesome (Manhattan usa seus próprios ícones) -->
    <context-param>
        <param-name>primefaces.FONT_AWESOME</param-name>
        <param-value>false</param-value>
    </context-param>

    <!-- Tema da aplicação (Manhattan) -->
    <context-param>
        <param-name>primefaces.THEME</param-name>
        <param-value>manhattan</param-value>
    </context-param>

    <!-- Modo de desenvolvimento (desabilitar para produção) -->
    <context-param>
        <param-name>jakarta.faces.PROJECT_STAGE</param-name>
        <param-value>Development</param-value>
    </context-param>

    <!-- Facelets Refresh Period (em segundos) -->
    <context-param>
        <param-name>jakarta.faces.FACELETS_REFRESH_PERIOD</param-name>
        <param-value>2</param-value>
    </context-param>

    <!-- State Saving Method -->
    <context-param>
        <param-name>jakarta.faces.STATE_SAVING_METHOD</param-name>
        <param-value>client</param-value>
    </context-param>

    <!-- Partial State Saving -->
    <context-param>
        <param-name>jakarta.faces.PARTIAL_STATE_SAVING</param-name>
        <param-value>true</param-value>
    </context-param>

    <!-- LISTENER -->
    <listener>
        <listener-class>jakarta.faces.event.PhaseListener</listener-class>
    </listener>

    <!-- ERROR PAGES -->
    <error-page>
        <error-code>404</error-code>
        <location>/error404.html</location>
    </error-page>

    <error-page>
        <error-code>500</error-code>
        <location>/error500.html</location>
    </error-page>

